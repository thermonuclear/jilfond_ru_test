# Application (используется Docker для container_name)
APP_NAME=jilfond_ru_test
APP_ENV=local

# Ports (host mapping)
NGINX_PORT=8080
MYSQL_PORT=3306
PHPMYADMIN_PORT=8081
REDIS_PORT=6379

# Database credentials (для Docker MySQL контейнера)
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=jilfond_ru_test
DB_USERNAME=jilfond_ru_test
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# Redis (для Docker Redis контейнера)
REDIS_HOST=redis
